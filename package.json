{
  "name": "cc-prompter",
  "version": "0.1.0",
  "description": "Vite plugin — Claude Code PTY sessions with code-inspector integration",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "panel.html",
    "inject.js"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "code-inspector-plugin": "^1.5.3",
    "express": "^4.21.2"
  },
  "optionalDependencies": {
    "node-pty-prebuilt-multiarch": "^0.10.1-pre.5"
  },
  "peerDependencies": {
    "vite": ">=5.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "tsup": "^8.0.0",
    "typescript": "~5.8.0",
    "vite": "^6.2.0"
  },
  "keywords": [
    "vite",
    "vite-plugin",
    "claude",
    "claude-code",
    "pty",
    "code-inspector"
  ],
  "license": "MIT"
}
