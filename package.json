{
  "name": "cc-prompter",
  "version": "0.3.1",
  "description": "Vite/Next.js plugin — Shift+Alt click element → Claude Code edits code → page auto-refreshes",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./next": {
      "types": "./dist/next-plugin.d.ts",
      "import": "./dist/next-plugin.js",
      "require": "./dist/next-plugin.cjs"
    },
    "./webpack": {
      "types": "./dist/webpack-plugin.d.ts",
      "import": "./dist/webpack-plugin.js",
      "require": "./dist/webpack-plugin.cjs"
    },
    "./client-entry": {
      "default": "./dist/client-entry.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/auenger/cc-prompter.git"
  },
  "homepage": "https://auenger.github.io/cc-prompter/",
  "bugs": "https://github.com/auenger/cc-prompter/issues",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "code-inspector-plugin": "^1.5.3",
    "express": "^4.21.2"
  },
  "optionalDependencies": {
    "node-pty-prebuilt-multiarch": "^0.10.1-pre.5",
    "@homebridge/node-pty-prebuilt-multiarch": "^1.0.0"
  },
  "peerDependencies": {
    "vite": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "tsup": "^8.0.0",
    "typescript": "~5.8.0",
    "vite": "^6.2.0"
  },
  "keywords": [
    "vite",
    "vite-plugin",
    "nextjs",
    "next.js",
    "webpack",
    "claude",
    "claude-code",
    "pty",
    "code-inspector",
    "ai",
    "copilot",
    "developer-tools"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}
